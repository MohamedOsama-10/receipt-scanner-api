# Copy this file to .env and fill in your values

# --- Azure Computer Vision (receipt image OCR — free tier) ---
# Create a free resource at: https://portal.azure.com
# Free tier: ~5,000 transactions/month (varies by region, rate-limited)
AZURE_CV_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com
AZURE_CV_KEY=your_32_char_azure_key_here

# --- Groq (text tasks — fast & free) ---
# Get your key at: https://console.groq.com
GROQ_API_KEY=your_groq_key_here

# --- App settings ---
DATABASE_URL=sqlite:///./money_tracker.db
UPLOAD_DIR=uploads
APP_NAME=Money Tracker
DEBUG=True
